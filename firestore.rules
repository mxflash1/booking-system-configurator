rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Client submissions - Allow anyone to create, allow reading for admin dashboard
    match /client_submissions/{submissionId} {
      // Anyone can submit (create new order)
      allow create: if true;
      
      // Allow reading for admin dashboard (consider adding authentication in production)
      // For now, anyone with the admin URL can view orders
      allow read, update, delete: if true;
    }
    
    // Admin users collection (for authentication)
    match /admin_users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

